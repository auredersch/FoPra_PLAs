    "# PLA Verluaf über Zeit\n",
    "if (\"timepoint\" %in% colnames(metadata)) {\n",
    "  \n",
    "  kinetic_our_data <- metadata %>%\n",
    "    filter(timepoint %in% c(\"0h\", \"24h\", \"48h\", \"72h\")) %>%\n",
    "    group_by(timepoint, celltype) %>%\n",
    "    summarise(\n",
    "      PLA_rate = sum(tolower(!!sym(pla_col)) == \"pla\", na.rm = TRUE) / n(),\n",
    "      .groups = \"drop\"\n",
    "    ) %>%\n",
    "    # Top 10 häufigsten Zelltypen\n",
    "    filter(celltype %in% names(sort(table(metadata$celltype), decreasing = TRUE)[1:10]))\n",
    "  \n",
    "  kinetic_our_data$timepoint <- factor(kinetic_our_data$timepoint, levels = c(\"0h\", \"24h\", \"48h\", \"72h\"))\n",
    "  \n",
    "  p_our_kinetics <- ggplot(kinetic_our_data, aes(x = timepoint, y = PLA_rate, group = celltype, color = celltype)) +\n",
    "    geom_line(size = 1.3) +\n",
    "    geom_point(size = 3) +\n",
    "    scale_y_continuous(labels = scales::percent_format()) +\n",
    "    scale_color_brewer(palette = \"Set1\") +\n",
    "    theme_minimal(base_size = 14) +\n",
    "    labs(\n",
    "      title = \"Our Dataset: PLA Frequency Post-Infarction\",\n",
    "      x = \"Time after Myocardial Infarction\", \n",
    "      y = \"PLA Rate (%)\", \n",
    "      color = \"Cell Type\"\n",
    "    )\n",
    "  print(p_our_kinetics)\n",
    "  ggsave(paste0(output_dir, \"spec_our_infarct_kinetics_\", clean_name, \".png\"), plot = p_our_kinetics, width = 8, height = 5, dpi = 300)\n",
    "}\n",
    "\n",
    "\n",
    "# CHIP bei gesunden Patienten\n",
    "if (\"condition_all\" %in% colnames(metadata)) {\n",
    "  \n",
    "  chip_healthy_data <- metadata %>%\n",
    "    filter(condition_all %in% c(\"Healthy/CHIP-\", \"Healthy/CHIP+\"))\n",
    "  \n",
    "  if (nrow(chip_healthy_data) > 0) {\n",
    "    \n",
    "    p_chip_effect <- ggplot(chip_healthy_data, aes(x = condition_all, y = nCount_RNA, fill = condition_all)) +\n",
    "      geom_violin(alpha = 0.7, trim = FALSE, color = \"black\") +\n",
    "      geom_boxplot(width = 0.1, fill = \"white\", outlier.shape = NA, color = \"black\") +\n",
    "      scale_y_log10(labels = scales::trans_format(\"log10\", scales::math_format(10^.x))) +\n",
    "      scale_fill_manual(values = c(\"Healthy/CHIP-\" = \"#00bfc4\", \"Healthy/CHIP+\" = \"#7cae00\")) +\n",
    "      theme_minimal(base_size = 14) +\n",
    "      theme(legend.position = \"none\", panel.grid.major.x = element_blank()) +\n",
    "      labs(\n",
    "        title = \"Our Dataset: CHIP Mutation Effect in Healthy Donors\",\n",
    "        subtitle = \"Does CHIP alter cellular RNA depth before a heart attack?\",\n",
    "        x = \"Healthy Sub-Cohorts\", \n",
    "        y = \"Total UMI Counts per Cell (nCount_RNA Log10)\"\n",
    "      )\n",
    "    print(p_chip_effect)\n",
    "    ggsave(paste0(output_dir, \"spec_our_chip_healthy_effect_\", clean_name, \".png\"), plot = p_chip_effect, width = 7, height = 5, dpi = 300)\n",
    "  }\n",
    "}"
   ]
  },
