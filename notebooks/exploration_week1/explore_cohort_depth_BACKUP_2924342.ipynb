   "source": [
    "if (\"nCount_RNA\" %in% colnames(metadata_whole_plot)) {\n",
    "  \n",
    "  set.seed(123)\n",
    "  \n",
    "  library_depth <- metadata_whole_plot %>%\n",
    "  select(dataset, cohort, nCount_RNA) %>%\n",
    "  filter(\n",
    "    !is.na(cohort),\n",
    "    !is.na(nCount_RNA),\n",
    "    nCount_RNA > 0\n",
    "  )\n",
    "\n",
    "  library_depth_all <- bind_rows(\n",
    "    library_depth_all,\n",
    "    library_depth\n",
    "  )\n",
    "}"
   ]
