    }
   },
   "outputs": [],
   "source": [
    "combined_metadata <- map2_df(files, names, function(file, name) {\n",
    "  obj <- readRDS(paste0(data_path, file))\n",
    "  meta <- obj@meta.data\n",
    "  \n",
    "  #if (name == \"ImmuneAging\") { cohort_vec <- \"healthy\" }\n",
    "  #else if (name == \"Heart\") { cohort_vec <- if_else(meta$HF.etiology == \"Donor\", \"healthy\", \"diseased\") }\n",
    "  #else if (name == \"Sepsis\") { cohort_vec <- if_else(meta$Group == \"Adult Healthy Control\", \"healthy\", \"diseased\") }\n",
    "  #else if (name == \"Vaccine\") { cohort_vec <- if_else(meta$time == 0, \"healthy\", \"diseased\") }\n",
    "  #else if (name == \"OurDataset\") { cohort_vec <- if_else(meta$condition == \"Healthy\", \"healthy\", \"diseased\") }\n",
    "  \n",
    "  #Cohort = cohort_vec\n",
    "  data.frame(\n",
    "    Dataset = name,\n",
    "    nCount_RNA = meta$nCount_RNA\n",
    "  )\n",
    "})"
   ]
  },
