    "library(tidyverse)\n",
    "library(scales)\n",
    "\n",
    "data_path <- \"/nfs/home/students/f.mathis/SysBioMed-PLAs/data/datasets/\"\n",
    "files <- c(\"gated_ImmuneAging.rds\", \"gated_heart_processed.rds\", \"gated_sepsis_processed.rds\", \"gated_vaccine_processed.rds\", \"gated_our_dataset_processed.rds\")\n",
    "names <- c(\"ImmuneAging\", \"Heart\", \"Sepsis\", \"Vaccine\", \"OurDataset\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
